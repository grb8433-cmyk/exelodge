# SUPABASE KEYS (DEV)
# 1. Create a "ExeLodge-Dev" project in your Supabase dashboard.
# 2. Copy the URL and Anon Key to here.
# 3. Rename this file to .env locally.

EXPO_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key

# SCRAPER KEYS (DEV)
# Use your Service Role Key from the Dev project for the scraper to work.
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key
